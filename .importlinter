[importlinter]
root_package = prism

[importlinter:contract:clean_architecture]
type = layers
layers = [
    "prism.domain",
    "prism.application",
    "prism.infrastructure",
    "prism.interfaces",
]
ignore_imports = [
    "prism.domain.* -> prism.infrastructure.*",
    "prism.domain.* -> prism.interfaces.*",
    "prism.application.* -> prism.infrastructure.*",
    "prism.application.* -> prism.interfaces.*",
]

[importlinter:contract:domain_isolation]
type = forbidden
source = prism.domain
forbidden = [
    "prism.infrastructure",
    "prism.interfaces",
    "prism.application",
]

[importlinter:contract:application_isolation]
type = forbidden
source = prism.application
forbidden = [
    "prism.infrastructure",
    "prism.interfaces",
]

[importlinter:contract:infrastructure_implements_application]
type = independence
source = prism.infrastructure
other = prism.interfaces

[importlinter:contract:interfaces_depend_on_application]
type = independence
source = prism.interfaces
other = prism.infrastructure

[importlinter:contract:domain_bounded_contexts]
type = independence
modules = [
    "prism.domain.portfolio",
    "prism.domain.market",
    "prism.domain.risk",
    "prism.domain.ingestion",
    "prism.domain.strategy",
    "prism.domain.backtesting",
    "prism.domain.benchmark",
]

[importlinter:contract:no_circular_domain]
type = layers
layers = [
    "prism.domain.shared_kernel",
    "prism.domain.portfolio.entities",
    "prism.domain.portfolio.value_objects",
    "prism.domain.portfolio.events",
    "prism.domain.portfolio.repositories",
    "prism.domain.portfolio.services",
    "prism.domain.market.entities",
    "prism.domain.market.value_objects",
    "prism.domain.market.events",
    "prism.domain.market.repositories",
    "prism.domain.market.services",
    "prism.domain.risk.entities",
    "prism.domain.risk.value_objects",
    "prism.domain.risk.events",
    "prism.domain.risk.repositories",
    "prism.domain.risk.services",
    "prism.domain.ingestion.entities",
    "prism.domain.ingestion.value_objects",
    "prism.domain.ingestion.events",
    "prism.domain.ingestion.repositories",
    "prism.domain.ingestion.services",
    "prism.domain.strategy.entities",
    "prism.domain.strategy.value_objects",
    "prism.domain.strategy.events",
    "prism.domain.strategy.repositories",
    "prism.domain.strategy.services",
    "prism.domain.backtesting.entities",
    "prism.domain.backtesting.value_objects",
    "prism.domain.backtesting.events",
    "prism.domain.backtesting.repositories",
    "prism.domain.backtesting.services",
    "prism.domain.benchmark.entities",
    "prism.domain.benchmark.value_objects",
    "prism.domain.benchmark.events",
    "prism.domain.benchmark.repositories",
    "prism.domain.benchmark.services",
]